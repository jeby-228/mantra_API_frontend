{
	"name": "my-skeleton-app",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write . ",
		"test:unit": "vitest",
		"test": "pnpm run test:unit -- --run",
		"test:watch": "pnpm run test:unit -- --watch",
		"test:coverage": "vitest run --coverage",
		"graphql:codegen": "graphql-codegen --config codegen.ts",
		"graphql:watch": "graphql-codegen --config codegen.ts --watch"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.1",
		"@eslint/js": "^9.39.2",
		"@graphql-codegen/cli": "^6.1.3",
		"@graphql-codegen/typescript": "^5.0.9",
		"@graphql-codegen/typescript-operations": "^5.0.9",
		"@graphql-codegen/typescript-urql": "^5.0.0",
		"@skeletonlabs/skeleton": "^4.11.0",
		"@skeletonlabs/skeleton-svelte": "^4.11.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.53.3",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/forms": "^0.5.11",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.1.18",
		"@types/node": "^20",
		"@vitest/browser-playwright": "^4.0.18",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.14.0",
		"globals": "^17.1.0",
		"playwright": "^1.58.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.4.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.53.5",
		"svelte-check": "^4.3.5",
		"tailwindcss": "^4.1.18",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.53.1",
		"vite": "^7.3.1",
		"vitest": "^4.0.18",
		"vitest-browser-svelte": "^2.0.2"
	},
	"dependencies": {
		"@lucide/svelte": "^0.563.1",
		"@urql/svelte": "^5.0.0",
		"@vercel/analytics": "^1.6.1",
		"@vercel/speed-insights": "^1.3.1",
		"@vitest/coverage-v8": "^4.0.18",
		"graphql": "^16.13.1",
		"graphql-tag": "^2.12.6",
		"lucide-svelte": "^0.563.0",
		"super-sitemap": "^1.0.7"
	},
	"pnpm": {
		"overrides": {
			"cookie": ">=0.7.0",
			"fast-xml-parser": ">=5.3.6",
			"rollup": ">=4.59.0"
		}
	}
}
